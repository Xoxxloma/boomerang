# --- Telegram ---
# Токен от @BotFather для @Boomerang_bot
BOT_TOKEN=

# --- База данных (совпадает с docker-compose.yml; хост-порт 5433) ---
DATABASE_URL=postgres://boomerang:boomerang@localhost:5433/boomerang
# Прод (облако, напр. Neon): direct/unpooled endpoint + SSL.
# НЕ pooler/transaction-режим — pg-boss требует session-соединения (LISTEN/NOTIFY, advisory locks).
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx.REGION.aws.neon.tech/boomerang?sslmode=require
# DATABASE_SSL=true

# --- AI: в v0.1 единый ключ OpenAI на LLM и эмбеддинги ---
OPENAI_API_KEY=

# LLM (классификация / именование кластеров / синтез).
# По умолчанию OpenAI. DeepSeek/Qwen — свап через LLM_BASE_URL + LLM_MODEL (OpenAI-совместимы).
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Эмбеддинги (фиксированы — смена потом = переэмбеддить базу).
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small

# --- Ops: алерты админам о критичных сбоях (опционально) ---
# tg-id админов через запятую — кому слать алерты бюджет-гарда: ответ API без usage (учёт расхода ослеп,
# лимиты фактически отключены) и сбой регидрации учёта на старте. Пусто/не задано → алерты выключены.
ADMIN_IDS=238116924

# --- Тюнинг качества (опционально, §12; подбирается на своём корпусе) ---
# Все значения опциональны — при отсутствии берутся дефолты из src/config/tuning.ts.
# Косинус-близость к центроиду, ниже которой заводится новый кластер.
CLUSTER_THRESHOLD=0.45
# Порог семантической похожести в поиске (ниже — отсекается как нерелевантное).
SEARCH_MIN_SIMILARITY=0.15
# Триграммная близость имени кластера к слову запроса (recall по названию категории).
CLUSTER_NAME_MATCH_THRESHOLD=0.45
# Режим 2: размер кластера, на котором шлём «тема созрела».
MATURITY_THRESHOLD=5
# Режим 2: минимальный возраст «старого соседа» (дней), чтобы показать резонанс.
RESONANCE_MIN_AGE_DAYS=10
# Режим 2: не показывать один и тот же старый материал чаще, чем раз в N дней.
RESONANCE_SURFACE_COOLDOWN_DAYS=30
# Режим 2: максимум проактивных РЕЗОНАНСОВ в сутки на пользователя (созревание не ограничивается).
PROACTIVE_DAILY_CAP=2
