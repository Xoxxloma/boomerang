# Все поля ОБЯЗАТЕЛЬНЫ — пустое поле = ошибка на старте (никаких опциональных фич/фолбэков).
# Базовые URL и имена моделей зашиты константами в src/ai/* — здесь только секреты и адреса.

# --- Telegram ---
# Токен от @BotFather для @Boomerang_bot
BOT_TOKEN=

# --- База данных (dev: совпадает с docker-compose.yml; хост-порт 5433) ---
DATABASE_URL=postgres://boomerang:boomerang@localhost:5433/boomerang
DATABASE_SSL=false
# Прод (self-host на VPS, см. docker-compose.prod.yml): БД в Docker на том же хосте, порт на loopback.
# <DB_PASSWORD> ниже = пароль БД (поле DB_PASSWORD), они должны совпадать.
# DATABASE_URL=postgres://boomerang:<DB_PASSWORD>@127.0.0.1:5432/boomerang
# DATABASE_SSL=false   # loopback, TLS не нужен; pg-boss тогда без ssl
# Прямое локальное соединение = full session (LISTEN/NOTIFY, advisory locks) — pg-boss доволен.

# --- self-host БД и морда pgweb (ТОЛЬКО прод; читаются docker-compose.prod.yml через --env-file) ---
# Node-приложению они не нужны (env.ts их игнорирует) — нужны контейнерам БД и морды.
# DB_PASSWORD=<надёжный-пароль-БД>          # = пароль в DATABASE_URL выше
# PGWEB_AUTH_USER=<логин-для-морды-pgweb>   # морда сама спросит логин/пароль (HTTP basic auth)
# PGWEB_AUTH_PASS=<пароль-для-морды-pgweb>

# --- OpenAI: один ключ на LLM (gpt-4o-mini), эмбеддинги (text-embedding-3-small) и vision ---
OPENAI_API_KEY=

# --- STT: транскрипция голосовых/аудио/видео. Groq whisper (НЕ OpenAI), ключ: https://console.groq.com ---
STT_API_KEY=

# --- Алерты админам о критичных сбоях (бюджет-гард ослеп и т.п.): tg-id через запятую ---
ADMIN_IDS=

# --- Telegram Mini App (вебапп: Карта / Поиск / Эхо) ---
# Публичный https-URL, под которым Caddy отдаёт Mini App. Должен совпадать с доменом в deploy/Caddyfile
# и быть прописан у бота (@BotFather → /setmenubutton, либо ставится автоматически из кода).
# Без своего домена: бесплатный nip.io — хостнейм <IP>.nip.io сам резолвится в этот IP (ниже — прод-IP).
WEBAPP_URL=https://147.45.152.170.nip.io
# Локальный порт HTTP-сервера Mini App (за Caddy). В dev должен совпадать с proxy в vite.config.ts (8787).
WEB_PORT=8787
